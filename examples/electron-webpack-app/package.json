{
  "name": "example-electron-webpack-app",
  "version": "0.0.0",
  "private": true,
  "description": "electron-ipc-auto-import + webpack integration example.",
  "main": "out/main/index.js",
  "scripts": {
    "build": "webpack --config webpack.config.ts",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.ts",
    "start": "pnpm build && electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-ipc-auto-import": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "html-webpack-plugin": "^5.6.3",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  }
}
